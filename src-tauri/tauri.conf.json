{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
    "productName": "Prompt Library",
    "version": "1.0.0",
    "identifier": "com.promptlibrary.app",
    "build": {
        "frontendDist": "../renderer"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Prompt Library",
                "label": "main",
                "width": 1100,
                "height": 750,
                "minWidth": 800,
                "minHeight": 550,
                "decorations": false,
                "transparent": false,
                "center": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src ipc: http://ipc.localhost"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/icon.png",
            "icons/icon.ico"
        ],
        "windows": {
            "nsis": {
                "installMode": "currentUser"
            }
        }
    }
}